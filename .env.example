# ==============================================================================
# OmniSite FastAPI 백엔드 환경변수 정의 명세서 (.env.example)
# ==============================================================================
# 로컬 개발 시에는 본 파일을 복사하여 '.env' 파일로 이름을 바꾼 뒤 실제 값을 입력하여 가동합니다.
# 주의: '.env' 파일은 절대 Git 원격 저장소에 커밋/푸시하지 마십시오.

# 1. API 및 서버 기본 설정
PROJECT_NAME="OmniSite FastAPI Monolith"
API_V1_STR="/api/v1"

# 2. 데이터베이스 설정 (PostgreSQL + PostGIS 공간 데이터베이스)
# 형식: postgresql://[사용자]:[비밀번호]@[호스트]:[포트]/[DB명]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omnisite"

# 3. AI 및 외부 지오코딩 API 설정
# OpenAI API Key (RAG 및 LangGraph 3자 토론용)
OPENAI_API_KEY="your-openai-api-key-here"

# 카카오 로컬 REST API Key (결측 주소 지오코딩 보정용)
# 발급처: https://developers.kakao.com
KAKAO_REST_API_KEY="your-kakao-rest-api-key-here"

# 국토교통부 Vworld API Key (공간 데이터 조회 및 대체 지오코딩용)
# 발급처: https://www.vworld.kr/dev/vkey.do
VWORLD_API_KEY="your-vworld-api-key-here"

# 4. 보안 및 JWT 인증 설정
# JWT 암호화 대칭키 (프로덕션 환경에서는 openssl rand -hex 32로 무작위 비밀키 발급 권장)
SECRET_KEY="super-secret-cryptographic-token-key-for-omnisite-jwt-signing"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080
